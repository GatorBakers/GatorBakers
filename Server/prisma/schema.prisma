
enum Account_Status {
  USER
  VENDOR
  ADMIN
}

enum Listing_Status {
  AVAILABLE
  PENDING
  SOLD
}

enum US_State {
  AL
  AK
  AZ
  AR
  CA
  CO
  CT
  DE
  FL
  GA
  HI
  ID
  IL
  IN
  IA
  KS
  KY
  LA
  ME
  MD
  MA
  MI
  MN
  MS
  MO
  MT
  NE
  NV
  NH
  NJ
  NM
  NY
  NC
  ND
  OH
  OK
  OR
  PA
  RI
  SC
  SD
  TN
  TX
  UT
  VT
  VA
  WA
  WV
  WI
  WY
  DC
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int             @id @default(autoincrement())
  email            String          @unique
  password         String
  first_name       String
  last_name        String
  photo_url        String?
  created_at       DateTime        @default(now())
  verified_account Boolean         @default(false)
  account_status   Account_Status?
  Coords           Coords?
  listings         Listing?
  Location         Location?
  orders           Order?
  token            Token?
}

model Token {
  token_id   Int      @id @default(autoincrement())
  user_id    Int      @unique
  token      String
  created_at DateTime @default(now())
  expired_at DateTime
  user       User     @relation(fields: [user_id], references: [id])
}

model Listing {
  id                  Int            @id @default(autoincrement())
  title               String
  description         String
  price               Decimal        @db.Decimal(10, 2)
  remaining_inventory Int
  listing_status      Listing_Status
  photo_url           String
  created_at          DateTime       @default(now())
  user_id             Int            @unique
  user                User           @relation(fields: [user_id], references: [id])
  location            Location?
}

model Coords {
  id        Int   @id @default(autoincrement())
  latitude  Float
  longitude Float
  user_id   Int   @unique
  User      User  @relation(fields: [user_id], references: [id])
}

model Location {
  id         Int      @id @default(autoincrement())
  city       String
  listing_id Int?     @unique
  user_id    Int?     @unique
  state      US_State
  listing    Listing? @relation(fields: [listing_id], references: [id])
  User       User?    @relation(fields: [user_id], references: [id])
}

model Order {
  id         Int            @id @default(autoincrement())
  created_at DateTime       @default(now())
  listing_id Int
  status     Listing_Status
  user_id    Int            @unique
  user       User           @relation(fields: [user_id], references: [id])
}